{
  "name": "karaoke-dj-panel",
  "version": "1.0.0",
  "description": "DJ Panel for Puerto Chopp Karaoke",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "package": "electron-packager . \"Puerto Chopp DJ\" --platform=win32 --arch=x64 --out=dist --overwrite --asar"
  },
  "author": "Puerto Chopp",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.puertochopp.karaokedj",
    "productName": "Puerto Chopp DJ",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    }
  }
}
